---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--z-midnight-950)] overflow-hidden">

  <!-- Wordmark grande -->
  <div class="footer-wordmark select-none" aria-hidden="true">
    <span class="font-display font-bold text-[var(--z-white)]">ZELLETY</span>
  </div>

  <!-- Bottom bar -->
  <div class="container-site flex items-center justify-between pb-8">
    <p class="label-mono text-[var(--z-slate-500)]">
      &copy;{year} Todos los derechos reservados Zellety
    </p>
    <a
      href="#"
      class="label-mono text-[var(--z-slate-500)] hover:text-[var(--z-white)] transition-colors duration-200"
      aria-label="Volver arriba"
    >
      Volver Arriba ↑
    </a>
  </div>

</footer>

<style>
  .footer-wordmark {
    display: flex;
    align-items: flex-end;
    padding: 0 clamp(0.5rem, 2vw, 1rem);
    line-height: 0.85;
    overflow: hidden;
  }
  .footer-wordmark span {
    font-size: clamp(5rem, 20vw, 18rem);
    letter-spacing: -0.03em;
    display: block;
    width: 100%;
    text-align: center;
  }
</style>
