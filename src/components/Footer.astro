---
const year = new Date().getFullYear();

const menuLinks = [
  { href: '/#inicio',    label: 'Home' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#works',     label: 'Works' },
  { href: '/#equipo',    label: 'Equipo' },
  { href: '/#contacto',  label: 'Contacto' },
];

const services = [
  'Web App',
  'App Móvil',
  'IoT / Domótica',
  'UX/UI Design',
  'SaaS',
];

const social = [
  { label: 'LinkedIn',  href: 'https://linkedin.com/company/zellety',  icon: '→' },
  { label: 'Instagram', href: 'https://instagram.com/zellety',          icon: '→' },
  { label: 'Twitter',   href: 'https://twitter.com/zellety',            icon: '→' },
];
---

<footer class="bg-[var(--z-midnight-950)] border-t border-[var(--z-midnight-800)]">
  <div class="container-site py-[var(--space-16)]">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Col 1: Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4" aria-label="Zellety">
          <div class="w-8 h-8 bg-[var(--z-lime-400)] rounded-sm flex items-center justify-center">
            <span class="font-display font-bold text-[var(--z-black)] text-sm leading-none">Z</span>
          </div>
          <span class="font-display font-bold text-[var(--z-white)] text-lg tracking-wide">ZELLETY</span>
        </a>
        <p class="text-[var(--z-slate-500)] text-sm leading-relaxed mb-6">
          Diseño y desarrollo tech para founders y equipos de producto en LATAM.
        </p>
        <p class="label-mono text-[var(--z-slate-500)] text-[0.65rem]">
          © {year} Zellety. Todos los derechos reservados.
        </p>
      </div>

      <!-- Col 2: Menu -->
      <div>
        <h3 class="label-mono mb-4">Menú</h3>
        <ul class="flex flex-col gap-2">
          {menuLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--z-slate-300)] hover:text-[var(--z-lime-400)] transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Servicios -->
      <div>
        <h3 class="label-mono mb-4">Servicios</h3>
        <ul class="flex flex-col gap-2">
          {services.map(s => (
            <li>
              <span class="text-sm text-[var(--z-slate-300)]">{s}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Social -->
      <div>
        <h3 class="label-mono mb-4">Social</h3>
        <ul class="flex flex-col gap-2">
          {social.map(s => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-[var(--z-slate-300)] hover:text-[var(--z-lime-400)] transition-colors duration-200"
              >
                <span>{s.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="divider mt-12 mb-6"></div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="label-mono text-[var(--z-slate-500)] text-[0.65rem]">
        Hecho con ♥ en LATAM
      </p>
      <p class="label-mono text-[var(--z-slate-500)] text-[0.65rem]">
        zellety.com
      </p>
    </div>

  </div>
</footer>
