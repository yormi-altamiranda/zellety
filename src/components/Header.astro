---
import NavMobile from './NavMobile.vue';
import ThemeToggle from './ThemeToggle.vue';

const navLinks = [
  { href: '/#nosotros',  label: 'Nosotros' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#works',     label: 'Portafolio' },
  { href: '/#equipo',    label: 'Equipo' },
  { href: '/#contacto',  label: 'Contacto' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container-site flex items-center justify-between h-16 md:h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 focus-ring rounded-sm" aria-label="Zellety — inicio">
      <div class="w-8 h-8 bg-[var(--z-lime-400)] rounded-sm flex items-center justify-center">
        <span class="font-display font-bold text-[var(--z-black)] text-sm leading-none">Z</span>
      </div>
      <span class="font-display font-bold text-lg tracking-wide hdr-text">ZELLETY</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-body text-sm hover:opacity-70 transition-opacity duration-200 focus-ring rounded-sm hdr-text"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop: Theme toggle -->
    <div class="hidden md:flex items-center hdr-toggle">
      <ThemeToggle client:load />
    </div>

    <!-- Mobile: toggle + menu -->
    <div class="flex md:hidden items-center gap-2">
      <div class="hdr-toggle">
        <ThemeToggle client:load />
      </div>
      <NavMobile client:load links={navLinks} />
    </div>

  </div>
</header>

<!-- Header background on scroll -->
<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (window.scrollY > 20) {
      header?.classList.add('is-scrolled');
    } else {
      header?.classList.remove('is-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  #site-header {
    background: transparent;
    --hdr-color: #ffffff;
  }
  #site-header .hdr-text {
    color: var(--hdr-color);
    transition: color 0.3s ease;
  }
  /* Dark theme scrolled — fondo oscuro, texto blanco */
  #site-header.is-scrolled {
    background: rgba(15, 15, 15, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #242424;
    --hdr-color: #ffffff;
  }
  /* Light theme scrolled — fondo claro, texto negro */
  :global([data-theme="light"]) #site-header.is-scrolled {
    background: rgba(239, 239, 239, 0.96);
    border-bottom-color: #e0e0e0;
    --hdr-color: #0A0F1E;
  }
  /* ThemeToggle hereda el color */
  #site-header .hdr-toggle {
    color: var(--hdr-color) !important;
    transition: color 0.3s ease;
  }
</style>
