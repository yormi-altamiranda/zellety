---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProjects, type MockProject } from '../../lib/mock-data';

export async function getStaticPaths() {
  const projects = getAllProjects();
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

interface Props {
  project: MockProject;
}

const { project } = Astro.props;
const allProjects = getAllProjects();
const otherProjects = allProjects.filter((p) => p.slug !== project.slug).slice(0, 4);

const SERVICE_LABELS: Record<string, string> = {
  web_app: 'Web App',
  mobile: 'App Móvil',
  iot: 'IoT / Domótica',
  ux_ui: 'UX/UI',
  saas: 'SaaS',
};

const serviceLabel = SERVICE_LABELS[project.services[0]] ?? project.services[0];

const date = new Date(project.published_at);
const dateStr = date
  .toLocaleDateString('es-419', { day: 'numeric', month: 'long', year: 'numeric' })
  .toUpperCase();

const meta = [
  { label: 'Año',       value: String(project.year) },
  { label: 'Cliente',   value: project.client_name || '—' },
  { label: 'Categoría', value: serviceLabel },
  { label: 'Stack',     value: project.tech_stack.slice(0, 2).join(' · ') || '—' },
];
---

<BaseLayout title={`${project.title} — Zellety`} description={project.summary}>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section
    class="project-hero relative flex flex-col items-center justify-center text-center"
    style="min-height: 88vh; padding: 140px 1.5rem 80px; background: var(--z-midnight-950);"
  >
    <!-- Dot pattern -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.045) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>

    <div class="relative z-10 w-full max-w-5xl mx-auto">
      <p class="font-mono text-[var(--z-slate-500)] mb-8 tracking-[0.3em] text-xs uppercase">
        {dateStr}
      </p>

      <h1
        class="project-title font-display font-bold text-[var(--z-white)] uppercase mb-8"
        style="font-size: clamp(3.5rem, 11vw, 9.5rem); line-height: 0.92; letter-spacing: -0.025em;"
      >
        {project.title}
      </h1>

      <p
        class="font-body text-[var(--z-slate-300)] mb-12 max-w-2xl mx-auto"
        style="font-size: 1.05rem; line-height: 1.75;"
      >
        {project.summary}
      </p>

      {project.url && (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-body font-semibold uppercase text-sm rounded-full transition-colors"
          style="letter-spacing: 0.14em; padding: 1rem 2.25rem; background: var(--z-white); color: var(--z-black);"
          onmouseover="this.style.background='var(--z-lime-400)'"
          onmouseout="this.style.background='var(--z-white)'"
        >
          Vista previa en vivo
        </a>
      )}
    </div>
  </section>

  <!-- ── Cover image full-width ────────────────────────── -->
  <div class="w-full overflow-hidden" style="max-height: 82vh;">
    <img
      src={project.cover_image.filename}
      alt={project.cover_image.alt}
      class="w-full object-cover"
      style="height: 82vh;"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- ── Metadata grid ──────────────────────────────────── -->
  <div class="bg-[var(--z-midnight-950)]">
    <div class="grid grid-cols-2 lg:grid-cols-4 border-b border-[var(--z-midnight-800)]">
      {meta.map((item, i) => (
        <div
          class={`p-8 lg:p-12 border-b lg:border-b-0 border-[var(--z-midnight-800)] ${i < 3 ? 'border-r border-[var(--z-midnight-800)]' : ''}`}
        >
          <p class="font-mono text-[var(--z-slate-500)] mb-3 tracking-[0.22em] uppercase" style="font-size: 0.65rem;">
            {item.label}
          </p>
          <p class="font-display font-bold text-[var(--z-white)] uppercase" style="font-size: clamp(1.1rem, 2.5vw, 1.8rem); letter-spacing: 0.02em;">
            {item.value}
          </p>
        </div>
      ))}
    </div>

    <!-- ── Content sections ──────────────────────────────── -->
    <div class="border-b border-[var(--z-midnight-800)]">

      <!-- Descripción -->
      <div class="grid grid-cols-1 lg:grid-cols-4 border-b border-[var(--z-midnight-800)]">
        <div class="lg:col-span-1 p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-[var(--z-midnight-800)]">
          <h3 class="font-display font-bold text-[var(--z-white)] uppercase tracking-[0.2em]" style="font-size: 0.8rem;">
            Descripción
          </h3>
        </div>
        <div class="lg:col-span-3 p-8 lg:p-12">
          <p class="font-body text-[var(--z-slate-300)]" style="font-size: 1rem; line-height: 1.85; max-width: 680px;">
            {project.description}
          </p>
        </div>
      </div>

      <!-- Tecnologías -->
      <div class="grid grid-cols-1 lg:grid-cols-4">
        <div class="lg:col-span-1 p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-[var(--z-midnight-800)]">
          <h3 class="font-display font-bold text-[var(--z-white)] uppercase tracking-[0.2em]" style="font-size: 0.8rem;">
            Tecnologías
          </h3>
        </div>
        <div class="lg:col-span-3 p-8 lg:p-12 flex flex-wrap gap-3">
          {project.tech_stack.map((t) => (
            <span
              class="font-mono text-sm px-4 py-2 rounded-full"
              style="background: var(--z-midnight-800); color: var(--z-slate-300); border: 1px solid var(--z-midnight-700);"
            >
              {t}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- ── Otros proyectos ────────────────────────────────── -->
  <div class="bg-[var(--z-midnight-950)] overflow-hidden pt-20">

    <!-- Marquee "MÁS PROYECTOS" -->
    <div
      class="overflow-hidden mb-14"
      style="mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);"
    >
      <div class="more-marquee flex whitespace-nowrap">
        {[0, 1, 2].map(() => (
          <span
            class="font-display font-bold shrink-0 text-[var(--z-white)] uppercase"
            style="font-size: clamp(3rem, 7vw, 6.5rem); line-height: 1; letter-spacing: -0.02em; padding-right: 2rem; opacity: 0.92;"
          >
            MÁS PROYECTOS&nbsp;&nbsp;·&nbsp;&nbsp;
          </span>
        ))}
      </div>
    </div>

    <!-- Grid de proyectos -->
    <div class="container-site pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
        {otherProjects.map((p) => (
          <a href={p.link} class="block group" aria-label={p.title}>
            <div class="overflow-hidden rounded-2xl mb-5" style="height: 300px;">
              <img
                src={p.cover_image.filename}
                alt={p.cover_image.alt}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="flex items-center justify-between">
              <div>
                <h4
                  class="font-display font-semibold text-[var(--z-white)] group-hover:text-[var(--z-lime-400)] transition-colors"
                  style="font-size: 1.15rem;"
                >
                  {p.title}
                </h4>
                <p class="font-mono text-[var(--z-slate-500)] tracking-widest uppercase mt-1" style="font-size: 0.65rem;">
                  {SERVICE_LABELS[p.services[0]] ?? p.services[0]}
                </p>
              </div>
              <span
                class="font-body text-[var(--z-lime-400)] text-2xl transition-transform duration-300 group-hover:translate-x-2 inline-block"
              >
                →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>

</BaseLayout>

<style>
  .more-marquee {
    animation: more-scroll 22s linear infinite;
  }
  @keyframes more-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    // Entrada del título
    gsap.from('.project-title', {
      opacity: 0,
      y: 60,
      duration: 0.9,
      ease: 'power3.out',
      delay: 0.15,
    });
  }
</script>
