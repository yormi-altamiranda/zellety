---
import ContactForm from '../components/ContactForm.vue';
---

<section id="contacto" class="bg-[var(--z-midnight-950)] pt-[var(--space-24)]">

  <!-- Form area -->
  <div class="container-site pb-[var(--space-24)]">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: copy -->
      <div>
        <p class="label-mono mb-5" style="color: var(--z-lime-400);">//CONTACTO</p>
        <h2
          class="contact-title font-display font-bold text-[var(--z-white)] mb-6"
          style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.02;"
        >
          Hablemos.
        </h2>
        <p class="font-body text-[var(--z-slate-300)] mb-10 max-w-sm" style="line-height: 1.7;">
          ¿Tienes un proyecto en mente? Escríbenos y te respondemos en menos de 24 horas.
        </p>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span class="label-mono text-[var(--z-lime-400)]">EMAIL</span>
            <a href="mailto:hola@zellety.com" class="font-body text-sm text-[var(--z-slate-300)] hover:text-[var(--z-white)] transition-colors">
              hola@zellety.com
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="label-mono text-[var(--z-lime-400)]">ZONA</span>
            <span class="font-body text-sm text-[var(--z-slate-300)]">UTC-3 a UTC-6 · LATAM</span>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <ContactForm client:visible />
      </div>

    </div>
  </div>

  <!-- ── Contact marquee ── -->
  <div class="overflow-hidden border-t border-[var(--z-midnight-800)] py-5">
    <div class="contact-marquee flex items-center whitespace-nowrap">
      {[0, 1, 2].map((_, i) => (
        <span class="flex items-center shrink-0 gap-10" aria-hidden={i > 0 ? 'true' : undefined}>
          <a href="mailto:info@zellety.com" class="contact-marquee-item font-display font-bold uppercase" style="font-size: 60px; color: var(--z-lime-400); letter-spacing: -0.01em;">
            Email: info@zellety.com
          </a>
          <span class="font-display font-bold select-none" style="font-size: 60px; color: var(--z-lime-400); opacity: 0.4;">·</span>
          <a href="tel:+58000000000" class="contact-marquee-item font-display font-bold uppercase" style="font-size: 60px; color: var(--z-lime-400); letter-spacing: -0.01em;">
            Llámanos: +58 000 000 000
          </a>
          <span class="font-display font-bold select-none" style="font-size: 60px; color: var(--z-lime-400); opacity: 0.4;">·</span>
          <a href="https://wa.me/580000000000" target="_blank" rel="noopener noreferrer" class="contact-marquee-item font-display font-bold uppercase" style="font-size: 60px; color: var(--z-lime-400); letter-spacing: -0.01em;">
            WhatsApp: +58 000 000 000
          </a>
          <span class="font-display font-bold select-none" style="font-size: 60px; color: var(--z-lime-400); opacity: 0.4; padding-right: 2.5rem;">·</span>
        </span>
      ))}
    </div>
  </div>

</section>

<style>
  .contact-marquee {
    animation: contact-scroll 30s linear infinite;
  }
  .contact-marquee:hover {
    animation-play-state: paused;
  }
  @keyframes contact-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  .contact-marquee-item {
    text-decoration: none;
    position: relative;
  }
  .contact-marquee-item::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--z-lime-400);
    transition: width 0.3s ease;
  }
  .contact-marquee-item:hover::after {
    width: 100%;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('.contact-title', {
      clipPath: 'inset(0 100% 0 0)',
      duration: 0.8,
      ease: 'power3.inOut',
      scrollTrigger: { trigger: '.contact-title', start: 'top 85%' },
    });
  }
</script>
