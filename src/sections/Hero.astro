---
const slides = [
  {
    image: 'https://picsum.photos/seed/zellety-slide-1/1920/1080',
    alt:   'Diseño y Desarrollo Zellety — Web Apps',
  },
  {
    image: 'https://picsum.photos/seed/zellety-slide-2/1920/1080',
    alt:   'Mobile y IoT LATAM',
  },
  {
    image: 'https://picsum.photos/seed/zellety-slide-3/1920/1080',
    alt:   'UX/UI y SaaS',
  },
];
---

<section
  id="inicio"
  class="relative overflow-hidden"
  style="height: 100svh; min-height: 600px; background: var(--z-midnight-950);"
>

  <!-- ── Slides de fondo ── -->
  {slides.map((slide, i) => (
    <div
      class="hero-slide absolute inset-0"
      data-slide={i}
      style={`opacity: ${i === 0 ? '1' : '0'}; transition: opacity 1s ease;`}
    >
      <img
        src={slide.image}
        alt={slide.alt}
        class="w-full h-full object-cover"
        loading={i === 0 ? 'eager' : 'lazy'}
        decoding="async"
      />
    </div>
  ))}

  <!-- Overlay oscuro -->
  <div
    class="absolute inset-0 z-10 pointer-events-none"
    style="background: rgba(10,15,30,0.62);"
  ></div>
  <!-- Gradiente extra desde abajo para texto -->
  <div
    class="absolute inset-0 z-10 pointer-events-none"
    style="background: linear-gradient(to top, rgba(10,15,30,0.95) 0%, rgba(10,15,30,0.3) 45%, transparent 100%);"
  ></div>

  <!-- ── Contenido ── -->
  <div class="absolute inset-0 z-20 flex flex-col justify-end" style="padding-bottom: 80px;">

    <!-- Texto principal + controles bottom -->
    <div class="container-site">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">

        <!-- Izquierda: headline + CTAs -->
        <div class="flex flex-col gap-5">
          <h1
            id="hero-headline"
            class="font-display font-bold opacity-0"
            style="font-size: clamp(2.8rem, 6.5vw, 5.5rem); line-height: 0.97; letter-spacing: -0.03em; color: #ffffff;"
          >
            Diseñamos y<br />
            construimos<br />
            <span style="color: var(--z-lime-400);">lo que imaginas.</span>
          </h1>

          <div id="hero-ctas" class="flex flex-wrap gap-3 opacity-0">
            <a href="/#contacto" class="btn-primary">
              Hablemos <span aria-hidden="true">→</span>
            </a>
            <a href="/#works" class="btn-ghost">
              Ver Trabajos
            </a>
          </div>
        </div>

        <!-- Derecha: descripción + dots -->
        <div class="flex flex-col items-start lg:items-end gap-6 lg:max-w-xs">
          <p
            id="hero-subline"
            class="font-body opacity-0 lg:text-right"
            style="font-size: 0.95rem; line-height: 1.7; color: rgba(255,255,255,0.65);"
          >
            Tu partner técnico en LATAM para Web Apps,
            Mobile, IoT, UX/UI y SaaS.
            Transformamos ideas en productos que escalan.
          </p>

          <!-- Slide dots -->
          <div id="hero-dots" class="flex items-center gap-2">
            {slides.map((_, i) => (
              <button
                class="hero-dot rounded-full transition-all duration-400 cursor-pointer"
                data-dot={i}
                style={
                  i === 0
                    ? 'width:24px; height:6px; background:var(--z-lime-400);'
                    : 'width:6px; height:6px; background:rgba(255,255,255,0.3);'
                }
                aria-label={`Slide ${i + 1}`}
              ></button>
            ))}
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- ── Flecha scroll ── -->
  <div
    id="hero-scroll-arrow"
    class="absolute z-20 left-1/2 opacity-0"
    style="bottom: 32px; transform: translateX(-50%);"
    aria-hidden="true"
  >
    <svg
      width="28" height="28" viewBox="0 0 28 28" fill="none"
      style="color: var(--z-lime-400);"
    >
      <path
        d="M14 4v20M6 16l8 8 8-8"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>

</section>

<style>
  @keyframes arrow-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);   }
    50%       { transform: translateX(-50%) translateY(8px); }
  }
  #hero-scroll-arrow {
    animation: arrow-bounce 1.6s ease-in-out infinite;
  }
</style>

<script>
  import gsap from 'gsap';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Entrada de texto
  if (!prefersReduced) {
    const tl = gsap.timeline({ delay: 0.2 });
    tl.to('#hero-headline', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' })
      .to('#hero-subline',  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      .to('#hero-ctas',     { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2')
      .to('#hero-scroll-arrow', { opacity: 0.75, duration: 0.4 }, '-=0.1');
  } else {
    gsap.set(['#hero-headline','#hero-subline','#hero-ctas','#hero-scroll-arrow'], { opacity: 1 });
  }

  // ── Slider auto-advance
  const SLIDES = document.querySelectorAll<HTMLElement>('.hero-slide');
  const DOTS   = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  let current  = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    SLIDES[current].style.opacity = '0';
    DOTS[current].style.width      = '6px';
    DOTS[current].style.height     = '6px';
    DOTS[current].style.background = 'rgba(255,255,255,0.3)';

    current = index;

    SLIDES[current].style.opacity  = '1';
    DOTS[current].style.width      = '24px';
    DOTS[current].style.height     = '6px';
    DOTS[current].style.background = 'var(--z-lime-400)';
  }

  function next() {
    goTo((current + 1) % SLIDES.length);
  }

  function startTimer() {
    timer = setInterval(next, 4500);
  }

  startTimer();

  DOTS.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      startTimer();
    });
  });
</script>
