---
// Hero — layout: copy izquierda, imágenes derecha
// Inspirado en la referencia: label + title + desc + CTA | imágenes rotadas con accents

interface Props {
  heroImage?: string;
  heroImage2?: string;
}

const {
  heroImage  = 'https://picsum.photos/seed/zellety-hero-a/600/750',
  heroImage2 = 'https://picsum.photos/seed/zellety-hero-b/500/650',
} = Astro.props;
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center bg-[var(--z-midnight-950)] overflow-hidden pt-20"
>
  <div class="container-site relative z-10 py-[var(--space-16)]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">

      <!-- ── Col izquierda: copy ── -->
      <div class="flex flex-col gap-6">

        <!-- Subtítulo / label -->
        <p id="hero-label" class="label-mono opacity-0" style="color: var(--z-lime-400);">
          DESIGN · DEV · LATAM
        </p>

        <!-- Título principal -->
        <h1
          id="hero-headline"
          class="font-display font-bold text-[var(--z-white)] opacity-0"
          style="font-size: clamp(2.6rem, 5.5vw, 5rem); line-height: 1.02; letter-spacing: -0.02em;"
        >
          Diseñamos y<br />
          construimos<br />
          <span style="color: var(--z-lime-400);">lo que imaginas.</span>
        </h1>

        <!-- Descripción -->
        <p
          id="hero-subline"
          class="font-body text-[var(--z-slate-300)] max-w-md opacity-0"
          style="font-size: 1rem; line-height: 1.7;"
        >
          Tu partner técnico en LATAM para Web Apps, Mobile, IoT, UX/UI y SaaS.
          Transformamos ideas en productos digitales que escalan.
        </p>

        <!-- CTAs -->
        <div id="hero-ctas" class="flex flex-wrap gap-3 opacity-0">
          <a href="/#contacto" class="btn-primary">
            Hablemos <span aria-hidden="true">→</span>
          </a>
          <a href="/#works" class="btn-ghost">
            Ver Trabajos
          </a>
        </div>

      </div>

      <!-- ── Col derecha: imágenes ── -->
      <div id="hero-images" class="relative h-[480px] lg:h-[560px] opacity-0">

        <!-- Accent strip top-right -->
        <div
          class="absolute top-0 right-4 w-14 h-40 rounded-sm z-10"
          style="background: var(--z-lime-400); transform: rotate(12deg); transform-origin: top right; opacity: 0.9;"
          aria-hidden="true"
        ></div>

        <!-- Accent strip bottom-left -->
        <div
          class="absolute bottom-8 left-8 w-10 h-28 rounded-sm z-10"
          style="background: var(--z-lime-400); transform: rotate(-15deg); opacity: 0.7;"
          aria-hidden="true"
        ></div>

        <!-- Imagen trasera (rotada) -->
        <div
          class="absolute top-8 right-12 w-[55%] overflow-hidden rounded-xl shadow-2xl z-20"
          style="transform: rotate(4deg); aspect-ratio: 4/5;"
        >
          <img
            src={heroImage2}
            alt="Proyecto Zellety"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
          <!-- overlay border accent -->
          <div
            class="absolute inset-0 rounded-xl"
            style="border: 2px solid var(--z-lime-400); opacity: 0.4;"
          ></div>
        </div>

        <!-- Imagen delantera (rotada inversa) -->
        <div
          class="absolute bottom-4 left-4 w-[58%] overflow-hidden rounded-xl shadow-2xl z-30"
          style="transform: rotate(-4deg); aspect-ratio: 3/4;"
        >
          <img
            src={heroImage}
            alt="Diseño y Desarrollo Zellety"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
          <!-- overlay tinte primary sutil -->
          <div
            class="absolute inset-0 rounded-xl"
            style="background: linear-gradient(135deg, var(--z-lime-400) 0%, transparent 50%); opacity: 0.15;"
          ></div>
        </div>

        <!-- Glow de fondo -->
        <div
          class="absolute inset-0 rounded-full pointer-events-none"
          style="background: radial-gradient(ellipse at center, var(--z-lime-400) 0%, transparent 65%); opacity: 0.06;"
          aria-hidden="true"
        ></div>

      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <span class="label-mono text-[0.6rem] text-[var(--z-slate-500)]">SCROLL</span>
    <div class="w-px h-10 bg-gradient-to-b from-[var(--z-slate-500)] to-transparent"></div>
  </div>

</section>

<script>
  import gsap from 'gsap';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    const tl = gsap.timeline({ delay: 0.15 });
    tl.to('#hero-label',   { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' })
      .to('#hero-headline', { opacity: 1, y: 0, duration: 0.65, ease: 'power3.out' }, '-=0.1')
      .to('#hero-subline',  { opacity: 1, y: 0, duration: 0.5,  ease: 'power2.out' }, '-=0.3')
      .to('#hero-ctas',     { opacity: 1, y: 0, duration: 0.4,  ease: 'power2.out' }, '-=0.2')
      .to('#hero-images',   { opacity: 1, x: 0, duration: 0.7,  ease: 'power2.out' }, '-=0.5');
  } else {
    gsap.set(['#hero-label','#hero-headline','#hero-subline','#hero-ctas','#hero-images'], { opacity: 1 });
  }
</script>
