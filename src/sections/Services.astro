---
const services = [
  {
    number: '/01',
    title: 'Web App',
    subtitle: 'Sites que convierten.',
    description: 'Corporativos, e-commerce y plataformas con Nuxt, Next y AstroJS. Rápidos, accesibles y optimizados.',
  },
  {
    number: '/02',
    title: 'App Móvil',
    subtitle: 'iOS y Android, un solo código.',
    description: 'Aplicaciones nativas con Flutter. Del prototipo al store en el menor tiempo posible.',
  },
  {
    number: '/03',
    title: 'IoT',
    subtitle: 'Hogares y oficinas inteligentes.',
    description: 'Automatización con sensores, dashboards y control remoto. Conectamos el mundo físico al digital.',
  },
  {
    number: '/04',
    title: 'UX/UI',
    subtitle: 'Diseño que comunica.',
    description: 'Research, wireframes, prototipos y design systems en Figma. Cada pixel tiene un propósito.',
  },
  {
    number: '/05',
    title: 'SaaS',
    subtitle: 'Plataformas que escalan.',
    description: 'Multi-tenant con billing, autenticación y dashboards. Del MVP al producto que crece.',
  },
];

const rows = [services.slice(0, 3), services.slice(3)];
---

<section id="servicios" class="section-padding bg-[var(--z-midnight-950)]">
  <div class="container-site">

    <!-- Header -->
    <div class="mb-16 lg:mb-24">
      <p class="label-mono mb-5" style="color: var(--z-lime-400);">//SERVICIOS</p>
      <h2
        class="services-title font-display font-bold text-[var(--z-white)] max-w-xl"
        style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.15;"
      >
        Combinamos creatividad y conocimiento técnico para hacer realidad tu visión.
      </h2>
    </div>

    <!-- Grid de servicios por filas -->
    {rows.map((row, ri) => (
      <div>
        <!-- Divider top -->
        <div class="divider mb-0"></div>

        <div class:list={[
          'grid gap-0',
          row.length === 3 ? 'grid-cols-1 md:grid-cols-3' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
        ]}>
          {row.map((service, i) => (
            <div
              class="service-grid-item group py-10 pr-8 border-b md:border-b-0 md:border-r border-[var(--z-midnight-800)] last:border-0 cursor-default"
            >
              <!-- Número -->
              <p
                class="font-mono text-sm mb-3 transition-colors duration-200 group-hover:text-[var(--z-lime-400)]"
                style="color: var(--z-slate-500);"
              >
                {service.number}
              </p>

              <!-- Título -->
              <h3
                class="font-display font-bold text-[var(--z-white)] mb-10"
                style="font-size: clamp(1.6rem, 2.5vw, 2.2rem); line-height: 1.1;"
              >
                {service.title}
              </h3>

              <!-- Subtítulo + descripción -->
              <p class="font-body font-semibold text-[var(--z-white)] text-sm mb-2">
                {service.subtitle}
              </p>
              <p class="font-body text-[var(--z-slate-300)] text-sm" style="line-height: 1.65;">
                {service.description}
              </p>
            </div>
          ))}
        </div>

        <!-- Divider bottom -->
        <div class="divider"></div>

        {ri === 0 && <div class="h-12"></div>}
      </div>
    ))}

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('.services-title', {
      clipPath: 'inset(0 100% 0 0)',
      duration: 0.8,
      ease: 'power3.inOut',
      scrollTrigger: { trigger: '.services-title', start: 'top 85%' },
    });
    gsap.from('.service-grid-item', {
      opacity: 0,
      y: 30,
      stagger: 0.1,
      duration: 0.5,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.service-grid-item', start: 'top 88%' },
    });
  }
</script>
