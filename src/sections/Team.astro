---
const team = [
  {
    name: 'Nombre Apellido',
    role: 'CEO & Co-founder',
    bio: 'Nuestro equipo de liderazgo está impulsado por una visión clara y un compromiso inquebrantable con la misión.',
    img: 'https://picsum.photos/seed/team-ceo/600/700',
    bg: 'var(--z-lime-400)',
  },
  {
    name: 'Nombre Apellido',
    role: 'CTO & Co-founder',
    bio: 'Arquitecto de soluciones con más de 8 años construyendo plataformas para startups y empresas en LATAM.',
    img: 'https://picsum.photos/seed/team-cto/600/700',
    bg: '#7c3aed',
  },
  {
    name: 'Nombre Apellido',
    role: 'Lead UX/UI Designer',
    bio: 'Diseñando experiencias que convierten. Research, prototipos y design systems que hablan el idioma del usuario.',
    img: 'https://picsum.photos/seed/team-design/600/700',
    bg: '#0ea5e9',
  },
];
---

<section id="equipo" class="section-padding bg-[var(--z-midnight-950)] overflow-hidden">
  <div class="container-site">

    <!-- Header -->
    <div class="mb-16">
      <p class="label-mono mb-4" style="color: var(--z-lime-400);">//Nuestro equipo</p>
      <h2
        class="team-title font-display font-bold text-[var(--z-white)]"
        style="font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.05;"
      >
        Team<br />members
      </h2>
    </div>

    <!-- Layout: TEAM watermark + cards -->
    <div class="relative">

      <!-- Watermark "TEAM" vertical -->
      <div
        class="hidden lg:block absolute left-0 top-0 bottom-0 select-none pointer-events-none z-0"
        aria-hidden="true"
        style="writing-mode: vertical-rl; text-orientation: mixed;"
      >
        <span
          class="font-display font-bold text-[var(--z-midnight-800)]"
          style="font-size: clamp(6rem, 14vw, 13rem); line-height: 1; letter-spacing: -0.05em;"
        >
          TEAM
        </span>
      </div>

      <!-- Cards stack -->
      <div class="lg:pl-[22%] flex flex-col">
        {team.map((member, i) => (
          <div class="team-member-row">

            <!-- Divider top -->
            {i > 0 && <div class="divider my-0"></div>}

            <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-8 items-center py-10">

              <!-- Foto -->
              <div
                class="relative overflow-hidden rounded-2xl"
                style={`aspect-ratio: 4/5; background: ${member.bg};`}
              >
                <img
                  src={member.img}
                  alt={member.name}
                  class="w-full h-full object-cover object-top mix-blend-luminosity"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <!-- Info -->
              <div class="flex flex-col gap-4">
                <p class="font-body text-[var(--z-slate-300)] text-sm" style="line-height: 1.7;">
                  {member.bio}
                </p>
                <div>
                  <p class="font-display font-semibold text-[var(--z-white)]" style="font-size: 1.1rem;">
                    {member.name}
                  </p>
                  <p class="font-mono text-xs mt-1" style="color: var(--z-slate-500);">
                    {member.role}
                  </p>
                </div>
              </div>

            </div>

            <!-- Divider bottom on last -->
            {i === team.length - 1 && <div class="divider"></div>}
          </div>
        ))}
      </div>

    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.from('.team-title', {
      clipPath: 'inset(0 100% 0 0)',
      duration: 0.8,
      ease: 'power3.inOut',
      scrollTrigger: { trigger: '.team-title', start: 'top 85%' },
    });
    gsap.from('.team-member-row', {
      opacity: 0,
      y: 50,
      stagger: 0.12,
      duration: 0.7,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.team-member-row', start: 'top 88%' },
    });
  }
</script>
