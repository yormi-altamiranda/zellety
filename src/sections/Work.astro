---
import { getAllProjects } from '../lib/mock-data';

const projects = getAllProjects();
---

<section id="works" class="works-section relative bg-[var(--z-midnight-950)] overflow-hidden">

  <!-- Header -->
  <div class="container-site flex items-center justify-between pt-[var(--space-24)] pb-12">
    <p class="font-body text-[var(--z-white)] text-base font-medium tracking-widest uppercase opacity-60">
      Proyectos
    </p>
    <a
      href="/projects"
      class="label-mono text-[var(--z-slate-500)] hover:text-[var(--z-lime-400)] transition-colors text-xs tracking-widest"
    >
      Ver todos →
    </a>
  </div>

  <!-- ── Desktop: horizontal pin scroll ── -->
  <div class="works-pin-wrapper hidden lg:block">
    <div
      class="works-cards-track flex items-start"
      style="padding-left: clamp(1rem,4vw,2rem); padding-right: clamp(1rem,4vw,2rem); gap: 2rem; width: max-content; padding-bottom: var(--space-24);"
    >
      {projects.map((project, i) => (
        <a
          href={project.link}
          class="works-card flex-shrink-0 block group"
          style="width: 560px;"
          aria-label={project.title}
        >
          <!-- Imagen -->
          <div
            class="overflow-hidden rounded-2xl"
            style="width: 560px; height: 360px;"
          >
            <img
              src={project.cover_image.filename}
              alt={project.cover_image.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Info -->
          <div class="pt-5 pr-4">
            <!-- número + tags -->
            <div class="flex items-center gap-3 mb-3">
              <span
                class="font-mono text-[var(--z-lime-400)]"
                style="font-size: 0.65rem; letter-spacing: 0.12em;"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              {project.tech_stack.slice(0, 3).map(t => (
                <span
                  class="font-mono text-[0.6rem] px-2 py-0.5 rounded-full"
                  style="background: var(--z-midnight-800); color: var(--z-slate-300); letter-spacing: 0.08em;"
                >
                  {t}
                </span>
              ))}
            </div>

            <h3
              class="font-display font-semibold text-[var(--z-white)] group-hover:text-[var(--z-lime-400)] transition-colors mb-2"
              style="font-size: 1.15rem; line-height: 1.25;"
            >
              {project.title}
            </h3>
            <p
              class="font-body text-[var(--z-slate-300)]"
              style="font-size: 0.875rem; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
            >
              {project.summary}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Mobile: grid vertical ── -->
  <div class="lg:hidden container-site pb-[var(--space-16)]">
    <div class="flex flex-col gap-10">
      {projects.map((project, i) => (
        <a
          href={project.link}
          class="block group"
          aria-label={project.title}
        >
          <div class="overflow-hidden rounded-2xl mb-4" style="height: 260px;">
            <img
              src={project.cover_image.filename}
              alt={project.cover_image.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="flex items-center gap-3 mb-2">
            <span class="font-mono text-[var(--z-lime-400)]" style="font-size: 0.65rem; letter-spacing: 0.12em;">
              {String(i + 1).padStart(2, '0')}
            </span>
            {project.tech_stack.slice(0, 2).map(t => (
              <span
                class="font-mono text-[0.6rem] px-2 py-0.5 rounded-full"
                style="background: var(--z-midnight-800); color: var(--z-slate-300);"
              >
                {t}
              </span>
            ))}
          </div>
          <h3
            class="font-display font-semibold text-[var(--z-white)] mb-1"
            style="font-size: 1.05rem;"
          >
            {project.title}
          </h3>
          <p class="font-body text-[var(--z-slate-300)]" style="font-size: 0.875rem; line-height: 1.55;">
            {project.summary}
          </p>
        </a>
      ))}
    </div>
  </div>

</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  (function initWorks() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isDesktop      = window.matchMedia('(min-width: 1024px)').matches;
    if (prefersReduced || !isDesktop) return;

    const section = document.querySelector<HTMLElement>('.works-section');
    const track   = document.querySelector<HTMLElement>('.works-cards-track');
    if (!section || !track) return;

    // Entrada de cards en stagger
    gsap.from('.works-card', {
      opacity: 0,
      y: 40,
      stagger: 0.1,
      duration: 0.6,
      ease: 'power2.out',
      immediateRender: false,
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        toggleActions: 'play none none none',
      },
    });

    // Pin + horizontal scroll
    const getScrollDist = () =>
      track.scrollWidth - window.innerWidth + parseFloat(getComputedStyle(track).paddingRight || '0');

    gsap.to(track, {
      x: () => -getScrollDist(),
      ease: 'none',
      scrollTrigger: {
        trigger: '.works-pin-wrapper',
        pin: true,
        scrub: 1,
        invalidateOnRefresh: true,
        end: () => '+=' + getScrollDist(),
        anticipatePin: 1,
      },
    });

    ScrollTrigger.refresh();
  })();
</script>
