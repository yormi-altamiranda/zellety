---
import { getFeaturedProjects } from '../lib/mock-data';

const projects = getFeaturedProjects();
const total    = 6; // total futuro en Storyblok
---

<section id="works" class="works-section relative bg-[var(--z-midnight-950)]">

  <!-- Header -->
  <div class="container-site flex items-center justify-between pt-[var(--space-24)] pb-10">
    <p class="font-body text-[var(--z-white)] text-base font-medium">Proyectos</p>
    <a href="/projects" class="label-mono text-[var(--z-slate-500)] hover:text-[var(--z-lime-400)] transition-colors">
      More +0{total < 10 ? '0' + total : total}
    </a>
  </div>

  <!-- ── Desktop: horizontal pin scroll ── -->
  <div class="works-pin-wrapper hidden lg:block">
    <div
      class="works-cards-track flex items-end pb-[var(--space-16)]"
      style="padding-left: clamp(1rem,4vw,2rem); gap: 0; width: max-content;"
    >
      {projects.map((project, i) => (
        <a
          href={project.link}
          class="works-card relative flex-shrink-0 overflow-hidden rounded-2xl block group"
          style={`
            width: 280px;
            height: 400px;
            margin-left: ${i === 0 ? '0' : '-30px'};
            margin-bottom: ${[20, 0, 40, 10, 30, 5][i % 6]}px;
            z-index: ${i + 1};
            transform-origin: bottom center;
          `}
          aria-label={project.title}
        >
          <!-- Imagen -->
          <img
            src={project.cover_image.filename}
            alt={project.cover_image.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />

          <!-- Overlay -->
          <div
            class="absolute inset-0 transition-opacity duration-300"
            style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);"
          ></div>

          <!-- Info inferior -->
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="font-mono text-[var(--z-slate-400)] mb-1" style="font-size: 0.6rem;">
              {project.month} {project.year}
            </p>
            <h3
              class="font-display font-semibold text-[var(--z-white)]"
              style="font-size: 0.95rem; line-height: 1.2;"
            >
              {project.title}
            </h3>
          </div>

          <!-- Tag hover -->
          <div
            class="absolute top-4 left-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          >
            {project.tech_stack.slice(0, 2).map(t => (
              <span
                class="inline-block font-mono text-[0.6rem] px-2 py-0.5 rounded-full mr-1"
                style="background: var(--z-lime-400); color: var(--z-black);"
              >
                {t}
              </span>
            ))}
          </div>

        </a>
      ))}
    </div>
  </div>

  <!-- ── Mobile: grid vertical ── -->
  <div class="lg:hidden container-site pb-[var(--space-16)]">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {projects.map((project) => (
        <a
          href={project.link}
          class="relative overflow-hidden rounded-2xl block group"
          style="height: 360px;"
        >
          <img
            src={project.cover_image.filename}
            alt={project.cover_image.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 60%);"
          ></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="font-mono text-[var(--z-slate-400)] mb-1" style="font-size: 0.6rem;">
              {project.month} {project.year}
            </p>
            <h3 class="font-display font-semibold text-[var(--z-white)]" style="font-size: 0.95rem;">
              {project.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>

</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  (function initWorks() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isDesktop      = window.matchMedia('(min-width: 1024px)').matches;
    if (prefersReduced || !isDesktop) return;

    const section = document.querySelector<HTMLElement>('.works-section');
    const track   = document.querySelector<HTMLElement>('.works-cards-track');
    if (!section || !track) return;

    // — Entrada inicial de cards con stagger (escala + fade)
    // immediateRender: false → no esconde las cards antes de que el trigger dispare
    gsap.from('.works-card', {
      opacity: 0,
      scale: 0.88,
      y: 40,
      stagger: 0.12,
      duration: 0.65,
      ease: 'power3.out',
      immediateRender: false,
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        toggleActions: 'play none none none',
      },
    });

    // — Pin + horizontal scroll
    const getScrollDist = () =>
      track.scrollWidth - (window.innerWidth - track.getBoundingClientRect().left);

    gsap.to(track, {
      x: () => -getScrollDist(),
      ease: 'none',
      scrollTrigger: {
        trigger: '.works-pin-wrapper',
        pin: true,
        scrub: 1.2,
        invalidateOnRefresh: true,
        end: () => '+=' + getScrollDist(),
        anticipatePin: 1,
      },
    });

    // — Cada card gana z-index al entrar al centro (efecto spotlight)
    gsap.utils.toArray<HTMLElement>('.works-card').forEach((card, i) => {
      gsap.to(card, {
        scale: 1.04,
        zIndex: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.works-pin-wrapper',
          scrub: true,
          start: `top+=${i * 80} top`,
          end: `top+=${i * 80 + 120} top`,
        },
      });
    });

    ScrollTrigger.refresh();
  })();
</script>
